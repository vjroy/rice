[global]
  monitor = 0
  follow = mouse

  width = 320
  height = 200
  origin = top-right
  offset = 10x10
  scale = 0

  notification_limit = 5

  progress_bar = true
  progress_bar_height = 10
  progress_bar_frame_width = 1
  progress_bar_min_width = 150
  progress_bar_max_width = 300

  indicate_hidden = yes
  transparency = 8
  separator_height = 2
  padding = 10
  horizontal_padding = 12
  text_icon_padding = 10
  frame_width = 2
  frame_color = "#fabd2f"
  gap_size = 6
  separator_color = frame
  sort = yes

  font = JetBrainsMono Nerd Font 11
  line_height = 0
  markup = full
  format = "<b>%s</b>\n%b"
  alignment = left
  vertical_alignment = center
  show_age_threshold = 60
  ellipsize = middle
  ignore_newline = no
  stack_duplicates = true
  hide_duplicate_count = false
  show_indicators = yes

  enable_recursive_icon_lookup = true
  icon_theme = Ant-Dark
  icon_position = left
  min_icon_size = 32
  max_icon_size = 32

  corner_radius = 8
  ignore_dbusclose = false

  mouse_left_click = close_current
  mouse_middle_click = do_action, close_current
  mouse_right_click = close_all

[experimental]
  per_monitor_dpi = false

[urgency_low]
  background = "#282828"
  foreground = "#ebdbb2"
  frame_color = "#8ec07c"
  timeout = 5

[urgency_normal]
  background = "#282828"
  foreground = "#ebdbb2"
  frame_color = "#fabd2f"
  timeout = 8

[urgency_critical]
  background = "#282828"
  foreground = "#fb4934"
  frame_color = "#fb4934"
  timeout = 0
